{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "insertFinalNewline": true,
  "sortImports": {},
  "sortPackageJson": { "sortScripts": false },
  "sortTailwindcss": {
    "functions": ["clsx", "cn", "tw"],
  },
  "ignorePatterns": [
    "node_modules/**",
    ".next/**",
    "dist/**",
    "drizzle/meta/**",
    "*.md",
  ],
}
